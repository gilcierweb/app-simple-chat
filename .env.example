# --- Simple Chat - Configuration Example ---

# -- PostgreSQL
POSTGRES_PASSWORD=secret

# -- Redis
REDIS_PASSWORD=redissecret

# -- MinIO (Object Storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioasecret

# -- Security (CRITICAL)
# Generate a strong 32-character or longer string for production
JWT_SECRET=replace_me_with_a_secure_random_string_at_least_32_chars
# Key for database-level field encryption (32 bytes base64 or hex)
DB_ENCRYPTION_KEY=replace_me_with_a_secure_random_base64_string_32_bytes

# -- SMTP (Email)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@simplechat.local

# -- Frontend URL
FRONTEND_URL=http://localhost

# -- Public Variables (passed to Nuxt)
NUXT_PUBLIC_API_BASE=http://localhost/api/v1
NUXT_PUBLIC_WS_URL=ws://localhost/api/v1/ws
NUXT_PUBLIC_APP_NAME="Simple Chat"

# -- Deployment (Nginx)
HTTP_PORT=80
HTTPS_PORT=443
